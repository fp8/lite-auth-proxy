# .gcloudignore - Allowlist approach: exclude everything, include only what Cloud Build needs
#
# Cloud Build needs: go.mod, go.sum, cmd/, internal/, config/, Dockerfile.*, cloudbuild.yaml
#
# See: https://cloud.google.com/sdk/gcloud/reference/topic/gcloudignore

# Exclude everything
*

# Include Go source and modules
!go.mod
!go.sum
!cmd/
!internal/

# Include Docker build files
!Dockerfile.flex
!Dockerfile.lite

# Include default config (copied into Docker image)
!config/

# Include Cloud Build config
!cloudbuild.yaml
