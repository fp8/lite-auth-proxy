# Environment Variables for lite-auth-proxy Tests
# Copy this file to .env and fill in your values for testing
# Note: .env file should not be committed to git

# ============================================================================
# Google Cloud Configuration for Real-World JWT Tests
# ============================================================================

# Google Cloud Project ID (where your Firebase project and Secret Manager are)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Name of the secret in Secret Manager containing the Firebase API Key
# The secret value itself is managed in GCP Secret Manager
FIREBASE_API_KEY_SECRET_NAME=firebase-api-key-dev

# Name of the secret in Secret Manager containing Firebase login credentials (email:password)
# The secret value itself is managed in GCP Secret Manager
FIREBASE_LOGIN_SECRET_NAME=firebase-login-credentials-dev


# ============================================================================
# End-to-End (e2e) Test Overrides — see e2e/README.md
# ============================================================================
# These are read by the Gherkin/behave e2e suite (e2e/run.sh loads this file).
# All are OPTIONAL — the suite ships with working defaults for the fp8devel
# project, so you only need these to point at a different project/secret/key.
# (Defaults are shown after each "=" for reference; uncomment to override.)

# GCP project holding the Firebase Web API key and the login secret
# E2E_FIREBASE_PROJECT=fp8devel

# Secret (in E2E_FIREBASE_PROJECT) holding the Firebase Web API key
# E2E_FIREBASE_API_KEY_SECRET=APIKEY_FIREBASE_AUTH_DEV

# Secret (in E2E_FIREBASE_PROJECT) holding the test login as "<email>:<password>"
# E2E_FIREBASE_LOGIN_SECRET=LOGIN_FIREBASE_AUTH_DEV

# Supply a Bearer token directly and skip the Firebase sign-in (e.g. in CI).
# When set, gcloud is not needed for the JWT scenarios.
# E2E_JWT_TOKEN=

# The API key the flex proxy expects (the suite sends this value, and the local
# proxy container is configured to accept it). Default matches API_KEY_SECRET.
# E2E_API_KEY=test-api-key-123456
# E2E_API_KEY_HEADER=X-API-KEY

# run.sh reuses the existing local image by default. Set this to (re)build it.
# E2E_BUILD_IMAGE=1
